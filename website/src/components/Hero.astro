---
import TerminalDemo from "./TerminalDemo.astro";
---

<section id="top" class="relative overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-60 [mask-image:linear-gradient(to_bottom,black,transparent_85%)]"></div>
  <div class="container-tight relative pt-16 pb-20 sm:pt-24 sm:pb-28 grid lg:grid-cols-[minmax(0,1.05fr)_minmax(0,1fr)] gap-12 lg:gap-16 items-center">
    <div class="animate-fade-up">
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-clam-sage animate-pulse"></span>
        Open source · MIT · GTK4 / libadwaita
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-white leading-[1.05]">
        Antivirus,
        <span class="relative inline-block">
          <span class="hero-gradient-text bg-gradient-to-r from-clam-sage via-white to-clam-sky bg-clip-text text-transparent">native</span>
          <svg
            class="absolute -bottom-1 left-0 w-full"
            viewBox="0 0 200 8"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M2 5.5 Q 50 1 100 4.5 T 198 3"
              stroke="#3d7a4e"
              stroke-width="2.5"
              stroke-linecap="round"
              fill="none"
            ></path>
          </svg>
        </span>
        to your Linux desktop.
      </h1>
      <p class="mt-6 lede max-w-xl">
        ClamUI is a modern graphical front-end for ClamAV. Real scan profiles,
        a hash-verified quarantine, a system security audit — packaged like a
        proper GNOME app, with nothing phoning home.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#install" class="btn-primary">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12"></path>
            <path d="m7 10 5 5 5-5"></path>
            <path d="M5 21h14"></path>
          </svg>
          Install ClamUI
        </a>
        <a
          href="https://github.com/linx-systems/clamui"
          rel="noopener"
          class="btn-ghost"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.73.5.77 5.46.77 11.73c0 4.98 3.23 9.21 7.71 10.7.56.1.77-.24.77-.54v-2.07c-3.14.68-3.8-1.35-3.8-1.35-.52-1.3-1.27-1.65-1.27-1.65-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.51-.28-5.15-1.26-5.15-5.6 0-1.24.44-2.25 1.17-3.04-.12-.28-.51-1.43.11-2.98 0 0 .95-.3 3.12 1.16.9-.25 1.87-.37 2.84-.38.96.01 1.93.13 2.84.38 2.17-1.46 3.12-1.16 3.12-1.16.62 1.55.23 2.7.11 2.98.73.79 1.17 1.8 1.17 3.04 0 4.35-2.65 5.32-5.17 5.6.41.35.77 1.04.77 2.11v3.13c0 .3.21.65.78.54 4.47-1.49 7.7-5.72 7.7-10.7C23.23 5.46 18.27.5 12 .5z"></path>
          </svg>
          Star on GitHub
        </a>
        <div class="text-xs text-white/45 font-mono ml-1">
          Flatpak · .deb · AppImage · Source
        </div>
      </div>

      <dl class="mt-10 grid grid-cols-3 gap-4 max-w-lg">
        <div>
          <dt class="text-[11px] uppercase tracking-wider text-white/40 font-mono">Signatures</dt>
          <dd class="text-lg font-semibold text-white mt-1">8.7M+</dd>
        </div>
        <div>
          <dt class="text-[11px] uppercase tracking-wider text-white/40 font-mono">Telemetry</dt>
          <dd class="text-lg font-semibold text-white mt-1">Zero</dd>
        </div>
        <div>
          <dt class="text-[11px] uppercase tracking-wider text-white/40 font-mono">License</dt>
          <dd class="text-lg font-semibold text-white mt-1">MIT</dd>
        </div>
      </dl>
    </div>

    <div class="relative animate-fade-up [animation-delay:120ms]">
      <div class="absolute -inset-8 bg-clam-forest/10 blur-3xl rounded-full -z-10"></div>
      <div class="relative">
        <div class="relative z-10">
          <TerminalDemo />
        </div>
        <div class="relative -mt-6 ml-10 sm:ml-16 z-20">
          <img
            src="/screenshots/main_view_with_scan_result.png"
            alt="ClamUI showing a completed scan with one detected threat"
            width="1200"
            height="780"
            class="shot"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>
