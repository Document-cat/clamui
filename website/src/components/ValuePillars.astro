---
const pillars = [
  {
    title: "Native to GNOME",
    body: "GTK4 + libadwaita. Follows your system theme, your font size, your accent — not a repackaged Electron web app.",
    icon: "desktop",
  },
  {
    title: "Zero telemetry",
    body: "No analytics, no crash reporters, no metrics. VirusTotal is opt-in and API keys live in your system keyring.",
    icon: "shield",
  },
  {
    title: "Deep security toolbox",
    body: "Beyond AV: firewall & MAC audit, rootkit heuristics, scheduled scans via systemd timers, on-access via clamonacc.",
    icon: "tools",
  },
  {
    title: "Open source, honest",
    body: "MIT-licensed. Built in the open on GitHub. Contributions and issues welcome; no enterprise upsell behind the next click.",
    icon: "code",
  },
];
---

<section class="container-tight py-14 sm:py-20">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {
      pillars.map((p) => (
        <div class="card group hover:border-clam-forest/40 transition-colors">
          <div class="w-9 h-9 grid place-items-center rounded-lg bg-clam-forest/15 border border-clam-forest/25 text-clam-sage mb-4 group-hover:bg-clam-forest/25 transition-colors">
            {p.icon === "desktop" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="13" rx="2"></rect>
                <path d="M8 21h8M12 17v4"></path>
              </svg>
            )}
            {p.icon === "shield" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3 4 6v6c0 5 3.6 8.2 8 9 4.4-.8 8-4 8-9V6l-8-3z"></path>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
            )}
            {p.icon === "tools" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14.7 6.3a4 4 0 0 0-5.6 5.6L3 18v3h3l6.1-6.1a4 4 0 0 0 5.6-5.6l-2.1 2.1-2.8-2.8 2.1-2.1z"></path>
              </svg>
            )}
            {p.icon === "code" && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m8 6-6 6 6 6M16 6l6 6-6 6M14 4l-4 16"></path>
              </svg>
            )}
          </div>
          <h3 class="font-semibold text-white">{p.title}</h3>
          <p class="mt-1.5 text-sm text-white/65 leading-relaxed">{p.body}</p>
        </div>
      ))
    }
  </div>
</section>
