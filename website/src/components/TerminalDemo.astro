---
// Terminal demo with a GNOME-style headerbar (flat, centered title,
// single close affordance on the right) — not a macOS traffic-light.
---

<div class="term" aria-hidden="true">
  <div class="gnome-headerbar">
    <div class="flex-1"></div>
    <div class="gnome-title text-white/60">
      <span class="font-mono text-[11px]">Terminal — clamscan</span>
    </div>
    <div class="flex-1 flex justify-end">
      <span
        class="grid place-items-center h-6 w-6 rounded-full bg-white/[0.06] border border-white/10 text-white/50"
        aria-hidden="true"
      >
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </span>
    </div>
  </div>
  <div class="term-body space-y-1">
    <div>
      <span class="term-user">you</span><span class="term-dim">@</span><span class="term-prompt">fedora</span><span class="term-dim">:~$</span>
      <span class="ml-1">clamscan -r ~/Downloads</span>
    </div>
    <div class="term-dim">Loading signatures … 8,704,231 loaded</div>
    <div class="term-dim">Scanning /home/you/Downloads …</div>
    <div><span class="term-dim">/Downloads/invoice.pdf:</span> <span class="term-ok">OK</span></div>
    <div><span class="term-dim">/Downloads/setup.exe:</span> <span class="term-warn">Win.Trojan.Emotet-55519 FOUND</span></div>
    <div><span class="term-dim">/Downloads/archive.zip:</span> <span class="term-ok">OK</span></div>
    <div class="pt-2 border-t border-white/5 mt-2">
      <span class="term-dim">----------- SCAN SUMMARY -----------</span>
    </div>
    <div><span class="term-dim">Infected files:</span> <span class="term-warn">1</span></div>
    <div><span class="term-dim">Time:</span> 12.431 sec (0 m 12 s)</div>
    <div class="pt-3">
      <span class="term-user">you</span><span class="term-dim">@</span><span class="term-prompt">fedora</span><span class="term-dim">:~$</span>
      <span class="ml-1">clamui</span><span class="inline-block w-[9px] h-[15px] align-[-2px] bg-clam-sage ml-1 animate-caret-blink"></span>
    </div>
  </div>
</div>
