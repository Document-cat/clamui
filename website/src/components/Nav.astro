---
import ThemeToggle from "./ThemeToggle.astro";
import { getLatestRelease } from "../content/latest-release";

const release = await getLatestRelease();
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-clam-slate-ink/70 border-b hairline">
  <div class="container-tight flex items-center justify-between h-14">
    <div class="flex items-center gap-2">
      <a href="#top" class="flex items-center gap-2.5 group" aria-label="ClamUI home">
        <img
          src="/favicon.svg"
          alt=""
          width="28"
          height="28"
          class="rounded-md transition-transform group-hover:-rotate-6"
        />
        <span class="font-semibold tracking-tight text-white">ClamUI</span>
      </a>
      <a
        href={release.url}
        rel="noopener"
        title={`View ${release.tag} on GitHub`}
        class="hidden sm:inline-flex items-center text-xs font-mono text-white/45 border border-white/10 rounded px-1.5 py-0.5 hover:text-white hover:border-clam-sage/50 hover:bg-white/[0.04] transition-colors"
      >
        {release.tag}
      </a>
    </div>

    <nav class="hidden md:flex items-center gap-1 text-sm text-white/70">
      <a href="#features" class="px-3 py-2 rounded-md hover:text-white hover:bg-white/[0.04]">Features</a>
      <a href="#why" class="px-3 py-2 rounded-md hover:text-white hover:bg-white/[0.04]">Why Linux AV?</a>
      <a href="#install" class="px-3 py-2 rounded-md hover:text-white hover:bg-white/[0.04]">Install</a>
      <a
        href="https://github.com/linx-systems/clamui"
        rel="noopener"
        class="px-3 py-2 rounded-md hover:text-white hover:bg-white/[0.04]"
      >
        GitHub
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <a
        href="#install"
        class="btn-primary hidden sm:inline-flex"
      >
        Install
      </a>
    </div>
  </div>
</header>
