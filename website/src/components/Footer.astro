---
const year = new Date().getFullYear();
---

<footer class="border-t hairline mt-10">
  <div class="container-tight py-12 grid gap-10 sm:grid-cols-[auto_1fr_auto] items-start">
    <div class="flex items-center gap-2.5">
      <img src="/favicon.svg" alt="" width="24" height="24" class="rounded" />
      <span class="font-semibold tracking-tight text-white">ClamUI</span>
    </div>
    <nav class="grid grid-cols-2 sm:grid-cols-3 gap-6 text-sm">
      <div>
        <div class="text-white/40 text-[11px] uppercase tracking-wider font-mono mb-2">Project</div>
        <ul class="space-y-1.5">
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui" rel="noopener">Repository</a></li>
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/issues" rel="noopener">Issues</a></li>
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/releases" rel="noopener">Releases</a></li>
        </ul>
      </div>
      <div>
        <div class="text-white/40 text-[11px] uppercase tracking-wider font-mono mb-2">Docs</div>
        <ul class="space-y-1.5">
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/blob/master/docs/USER_GUIDE.md" rel="noopener">User guide</a></li>
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/blob/master/docs/INSTALL.md" rel="noopener">Install</a></li>
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/blob/master/docs/TROUBLESHOOTING.md" rel="noopener">Troubleshooting</a></li>
        </ul>
      </div>
      <div>
        <div class="text-white/40 text-[11px] uppercase tracking-wider font-mono mb-2">Legal</div>
        <ul class="space-y-1.5">
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/blob/master/LICENSE" rel="noopener">MIT License</a></li>
          <li><a class="text-white/75 hover:text-white" href="https://github.com/linx-systems/clamui/security" rel="noopener">Security</a></li>
        </ul>
      </div>
    </nav>
    <div class="text-xs text-white/45 sm:text-right">
      <div>Built with care for the Linux desktop.</div>
      <div class="mt-1 font-mono">© {year} ClamUI contributors</div>
    </div>
  </div>
</footer>
