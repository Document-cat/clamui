---
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="relative h-9 w-9 grid place-items-center rounded-md border border-white/10 text-white/70 hover:text-white hover:bg-white/[0.06] transition"
>
  <svg
    class="w-4 h-4 hidden dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg
    class="w-4 h-4 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const apply = () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn || (btn as any).dataset.bound) return;
    (btn as any).dataset.bound = "1";
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const isLight = root.classList.toggle("light");
      root.classList.toggle("dark", !isLight);
      try {
        localStorage.setItem("clamui-theme", isLight ? "light" : "dark");
      } catch (_) {}
    });
  };
  apply();
  document.addEventListener("astro:page-load", apply);
</script>
