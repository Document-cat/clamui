---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ValuePillars from "../components/ValuePillars.astro";
import FeatureRow from "../components/FeatureRow.astro";
import WhyLinuxAV from "../components/WhyLinuxAV.astro";
import InstallTabs from "../components/InstallTabs.astro";
import Footer from "../components/Footer.astro";
import { features } from "../content/features";
---

<Base>
  <Nav />
  <main id="main">
    <Hero />
    <ValuePillars />

    <section id="features" class="container-tight py-10 sm:py-16">
      <div class="max-w-2xl mb-10 sm:mb-16">
        <span class="eyebrow">A guided tour</span>
        <h2 class="mt-3 section-title">What's inside</h2>
        <p class="mt-4 lede">
          Six things ClamUI does that the command line can't — or won't.
        </p>
      </div>

      <div class="space-y-20 sm:space-y-28">
        {features.map((f, i) => <FeatureRow feature={f} index={i} />)}
      </div>
    </section>

    <WhyLinuxAV />
    <InstallTabs />
  </main>
  <Footer />
</Base>
